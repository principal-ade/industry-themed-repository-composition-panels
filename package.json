    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitejs/plugin-react": "^4.7.0",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
