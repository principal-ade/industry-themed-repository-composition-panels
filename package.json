{
  "name": "@industry-theme/repository-composition-panels",
  "version": "0.7.82",
  "description": "Repository composition panels including Git Changes panel for the panel framework",
  "type": "module",
  "main": "dist/panels.bundle.js",
  "module": "dist/panels.bundle.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/panels.bundle.js",
      "require": "./dist/panels.bundle.js",
      "default": "./dist/panels.bundle.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools.bundle.js",
      "require": "./dist/tools.bundle.js",
      "default": "./dist/tools.bundle.js"
    },
    "./og": {
      "types": "./dist/og.d.ts",
      "import": "./dist/og.bundle.js",
      "require": "./dist/og.bundle.js",
      "default": "./dist/og.bundle.js"
    }
  },
  "keywords": [
    "panel-extension"
  ],
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "build": "bun run clean && bun run build:panel && bun run build:tools && bun run build:og && bun run build:types",
    "build:panel": "NODE_ENV=production vite build",
    "build:tools": "bun build ./src/tools/index.ts --outfile ./dist/tools.bundle.js --format esm --target browser",
    "build:og": "NODE_ENV=production bun build ./src/og.ts --outfile ./dist/og.bundle.js --format esm --target node --external react --external react/jsx-runtime --external react/jsx-dev-runtime --external react-dom",
    "build:types": "tsc --project tsconfig.build.json --emitDeclarationOnly --declaration --declarationMap",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test --preload ./src/panels/overworld-map/test-setup.ts",
    "test:watch": "bun test --preload ./src/panels/overworld-map/test-setup.ts --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "generate-city": "bun scripts/generate-city-data.ts",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@principal-ade/dynamic-file-tree": ">=0.2.1",
    "@principal-ade/industry-theme": ">=0.1.8",
    "@principal-ade/panel-framework-core": ">=0.5.1",
    "@principal-ade/panel-layouts": ">=0.4.0",
    "@principal-ade/utcp-panel-event": ">=0.1.0",
    "@principal-ai/alexandria-collections": ">=1.4.6",
    "@principal-ai/alexandria-core-library": ">=0.3.2",
    "@principal-ai/codebase-composition": ">=0.2.44",
    "@principal-ai/file-city-builder": ">=0.4.6",
    "@principal-ai/file-city-react": ">=0.5.29",
    "@principal-ai/principal-view-core": ">=0.24.10",
    "@principal-ai/repository-abstraction": ">=0.5.7",
    "@react-spring/three": ">=10.0.0",
    "@react-three/drei": ">=10.0.0",
    "@react-three/fiber": ">=9.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "three": ">=0.170.0"
  },
  "peerDependenciesMeta": {
