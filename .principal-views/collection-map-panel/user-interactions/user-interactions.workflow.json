{
  "version": "1.0.0",
  "canvas": ".principal-views/collection-map-panel/collection-map-panel.otel.canvas",
  "name": "Project Drop",
  "description": "Drag and drop a project onto the collection map",
  "spanPattern": "collection-map.project-drop",
  "mode": "span-tree",
  "scenarios": [
    {
      "id": "project-dropped",
      "description": "Project dropped onto the map and positioned",
      "priority": 1,
      "template": {
        "summary": "Dropped {{repository.id}} onto map",
        "events": {
          "collection-map.project-drop": "Dropped {{repository.id}} at ({{grid.x}}, {{grid.y}})",
          "collection-map.project-moved": "Positioned in region {{region.id}} at ({{grid.x}}, {{grid.y}})"
        }
      }
    }
  ]
}
