{
  "nodes": [
    {
      "id": "collection-selected",
      "type": "otel-event",
      "label": "Collection Selected",
      "description": "Entry point when user selects a collection to view",
      "event": {
        "name": "collection-map.collection-selected",
        "attributes": {
          "collection.id": {
            "type": "string",
            "required": true
          },
          "collection.name": {
            "type": "string",
            "required": true
          },
          "members.count": {
            "type": "number",
            "required": true
          }
        }
      },
      "x": -100,
      "y": -224,
      "width": 250,
      "height": 100,
      "color": "#3b82f6",
      "otel": {
        "status": "implemented",
        "files": [
          "src/panels/CollectionMapPanel.tsx"
        ]
      }
    },
    {
      "id": "convert-nodes",
      "type": "otel-event",
      "label": "Convert Nodes",
      "description": "Transforms collection memberships + repositories to GenericNode format",
      "event": {
        "name": "collection-map.convert-nodes",
        "attributes": {
          "collection.id": {
            "type": "string",
            "required": true
          },
          "memberships.count": {
            "type": "number",
            "required": true
          },
          "repositories.count": {
            "type": "number",
            "required": true
          },
          "nodes.created": {
            "type": "number",
            "required": true
          }
        }
      },
      "x": -100,
      "y": -74,
      "width": 250,
      "height": 120,
      "color": "#22c55e",
      "otel": {
        "status": "implemented",
        "files": [
          "src/panels/CollectionMapPanel.tsx"
        ]
      }
    },
    {
      "id": "validate-nodes",
      "type": "otel-event",
      "label": "Validate Nodes",
      "description": "Splits nodes into valid (can render) and unplaced (need user placement)",
      "event": {
        "name": "collection-map.validate-nodes",
        "attributes": {
          "collection.id": {
            "type": "string",
            "required": true
          },
          "nodes.total": {
            "type": "number",
            "required": true
          },
          "nodes.valid": {
            "type": "number",
            "required": true
          },
          "nodes.unplaced": {
            "type": "number",
            "required": true
          },
          "is.initial.load": {
            "type": "boolean",
            "required": true
          }
        }
      },
      "x": 200,
      "y": -74,
      "width": 250,
      "height": 120,
      "color": "#22c55e",
      "otel": {
        "status": "implemented",
        "files": [
          "src/panels/CollectionMapPanel.tsx"
        ]
      }
    },
    {
      "id": "initialize-layout",
      "type": "otel-event",
      "label": "Initialize Layout",
      "description": "Runs layout engine to compute regions and positions (only on initial load)",
      "event": {
        "name": "collection-map.initialize-layout",
        "attributes": {
          "collection.id": {
            "type": "string",
            "required": true
          },
          "nodes.count": {
            "type": "number",
            "required": true
          },
          "needs.regions": {
            "type": "boolean",
            "required": true
          },
          "needs.layout": {
            "type": "boolean",
            "required": true
          },
          "regions.computed": {
            "type": "number",
            "required": false
          },
          "nodes.positioned": {
            "type": "number",
            "required": false
          }
        }
      },
      "x": -114,
      "y": 289,
      "width": 250,
      "height": 120,
      "color": "#22c55e",
      "otel": {
        "status": "implemented",
        "files": [
