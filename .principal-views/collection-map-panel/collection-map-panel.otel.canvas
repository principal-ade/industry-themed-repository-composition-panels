  "pv": {
    "name": "Collection Map Panel",
    "version": "2.1.0",
    "markdown": ".principal-views/collection-map-panel/collection-map-panel.md",
    "nodeTypes": {
      "boundary": {
        "description": "External boundary node representing host callbacks or external service calls",
        "label": "Host Boundary",
        "color": "#06b6d4",
        "icon": "ExternalLink",
        "shape": "rectangle"
      }
    },
    "edgeTypes": {
      "sequence": {
        "style": "solid",
        "color": "#64748b",
        "width": 2
      },
      "conditional": {
        "style": "dashed",
        "color": "#f59e0b",
        "width": 2
      },
      "triggers": {
        "style": "dotted",
        "color": "#8b5cf6",
        "width": 1
      },
      "host-call": {
        "style": "solid",
        "color": "#06b6d4",
        "width": 2
      }
    }
  }
