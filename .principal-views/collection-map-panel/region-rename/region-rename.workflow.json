{
  "version": "1.0.0",
  "canvas": ".principal-views/collection-map-panel/collection-map-panel.otel.canvas",
  "name": "Region Rename",
  "description": "Rename a region on the collection map",
  "spanPattern": "collection-map.region-renamed",
  "mode": "span-tree",
  "scenarios": [
    {
      "id": "region-renamed",
      "description": "User renamed a region",
      "priority": 1,
      "template": {
        "summary": "Renamed region to '{{region.new_name}}'",
        "events": {
          "collection-map.region-renamed": "Renamed region {{region.id}} to '{{region.new_name}}'"
        }
      }
    }
  ]
}
