{
  "version": "1.0.0",
  "canvas": ".principal-views/collection-map-panel/collection-map-panel.otel.canvas",
  "name": "Repository Click",
  "description": "User clicks on a repository sprite to select or deselect",
  "spanPattern": "collection-map.repository-clicked",
  "scenarios": [
    {
      "id": "repository-click",
      "description": "User clicked on a repository sprite or empty space to select/deselect",
      "priority": 1,
      "template": {
        "summary": "{{action}} repository {{repository.id}} in collection {{collection.id}}",
        "events": {
          "collection-map.repository-clicked": "Action: {{action}} - Clicked on {{repository.id}} in collection {{collection.id}}"
        }
      }
    }
  ]
}
